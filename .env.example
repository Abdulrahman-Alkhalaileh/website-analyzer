# Used for canonical URLs, Open Graph base, sitemap, and JSON-LD. No trailing slash.
# Example: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Footer watermark (shown at bottom of the page). Name is required to show the block.
# NEXT_PUBLIC_AUTHOR_NAME=Your Name
# GitHub: username only or full URL
# NEXT_PUBLIC_AUTHOR_GITHUB=yourusername
# LinkedIn: slug only (jane-doe), in/jane-doe, or full profile URL
# NEXT_PUBLIC_AUTHOR_LINKEDIN=jane-doe
# NEXT_PUBLIC_AUTHOR_EMAIL=you@example.com

# Optional: paste the content value from Google Search Console "HTML tag" verification.
# GOOGLE_SITE_VERIFICATION=
